# LLM Fine-Tuning Toolkit Configuration
# Copy to .env and customize

# Base model (HuggingFace model ID)
LFT_BASE_MODEL=mistralai/Mistral-7B-v0.3

# Quantization (4 or 8 bit)
LFT_QLORA_BITS=4

# LoRA hyperparameters
LFT_LORA_RANK=16
LFT_LORA_ALPHA=32
LFT_LORA_DROPOUT=0.05

# Training
LFT_LEARNING_RATE=2e-4
LFT_PER_DEVICE_BATCH_SIZE=4
LFT_GRADIENT_ACCUMULATION_STEPS=4
LFT_NUM_EPOCHS=3
LFT_MAX_SEQ_LENGTH=2048

# Paths
LFT_OUTPUT_DIR=./outputs
LFT_DATASET_DIR=./datasets

# GPU device (auto, cuda, mps, cpu)
LFT_DEVICE=auto

# HuggingFace token (optional, for gated models)
# LFT_HF_TOKEN=hf_xxxxx
